{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RAG Evaluation Output",
  "type": "object",
  "properties": {
    "retrieval_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "knowledge_complete": {
      "type": "boolean"
    },
    "knowledge_relevant": {
      "type": "boolean"
    },
    "missing_information": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "quality": {
      "type": "string",
      "enum": [
        "Excellent",
        "Good",
        "Fair",
        "Poor"
      ]
    },
    "reasoning": {
      "type": "string"
    }
  },
  "required": [
    "retrieval_score",
    "knowledge_complete",
    "knowledge_relevant",
    "missing_information",
    "quality",
    "reasoning"
  ],
  "additionalProperties": false
}
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Multi Intent Analysis Output",
  "type": "object",
  "properties": {
    "incident_count": {
      "type": "integer",
      "minimum": 1
    },
    "incidents": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "incident_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "incident_type": {
            "type": "string"
          }
        },
        "required": [
          "incident_id",
          "description",
          "incident_type"
        ],
        "additionalProperties": false
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reasoning": {
      "type": "string"
    }
  },
  "required": [
    "incident_count",
    "incidents",
    "relationships",
    "reasoning"
  ],
  "additionalProperties": false
}